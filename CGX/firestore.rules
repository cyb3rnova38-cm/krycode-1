rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Dashboard & System Statistics
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Live Chat System (Structured)
    match /chats/{userId} {
      // Admins can see all chats, users only their own metadata
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Anyone can create/update their chat metadata when sending messages
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());

      match /messages/{messageId} {
        // Users can read/write their own messages, Admins can do all
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    // User Registry (User Profiles)
    match /users/{userId} {
      // Users can manage their own profile, Admins can see all
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Our Works (Portfolio)
    match /portfolios/{portfolioId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin(); // Only admins can manage portfolio
    }

    // Promos (Special Offers)
    match /promos/{promoId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Blog Posts
    match /blogs/{blogId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Channels (Feeds & Chat Groups)
    match /channels/{channelId} {
      allow read: if request.auth != null; // Authenticated users can view channels
      allow write: if isAdmin();
    }

    // Brand Assets (Global Settings)
    match /assets/{assetId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }
  }
}