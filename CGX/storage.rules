rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public Assets (Our Works, Blog Images, Brand Assets)
    match /public/{allPaths=**} {
      allow read: if true; // Public access
      allow write: if isAdmin(); // Admin-only upload/delete
    }

    // User-specific content (Live Chat uploads, User profile pics)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Live Chat Session uploads
    match /chats/{sessionId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == sessionId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == sessionId || isAdmin());
    }

    // Dashboard & Admin-only System Assets
    match /system/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}